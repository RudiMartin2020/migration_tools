# SQLite 원본 DB '파일' 경로 (디렉터리 아님, 파일명까지 포함)
SQLITE_PATH=/home/laiwas/workspace/FLOPI/flopi_source/simulator.db

# PostgreSQL 접속 정보 (실제 값은 .env 에만 입력 — .env 는 git 제외)
PG_HOST=<PG_호스트_또는_VIP>
PG_PORT=5432
PG_USER=<계정>
PG_PASSWORD=<비밀번호>
PG_DB=<데이터베이스명>
PG_SCHEMA=public

# 한 번에 처리할 행 수
BATCH_SIZE=1000

# 증분 동기화 워터마크 상태 파일 경로
STATE_FILE=.flopi_db_sync_state.json

# 삭제 동기화(--delete) 허용 여부. 기본 false(차단).
# true 로 설정해야만 --delete 가 동작한다. (실수로 인한 대량 삭제 방지)
ALLOW_DELETE=false

# 동기화 후 PK 시퀀스(SERIAL/IDENTITY) 자동 보정 여부. 기본 false.
# 시퀀스 기반 PK + 앱이 PG에 직접 INSERT 하는 경우 true 권장.
SYNC_SEQUENCE=false

# PK 중복은 무시하고 신규만 INSERT(변경분 UPDATE 안 함). 기본 false.
# true 면 ON CONFLICT DO NOTHING 동작.
INSERT_ONLY=false

# 원본에 있고 PG에 없는 컬럼을 ALTER ADD COLUMN 으로 자동 추가. 기본 false.
# (테이블 생성은 안 함 / 삭제·타입변경은 경고만)
ADD_COLUMNS=false
